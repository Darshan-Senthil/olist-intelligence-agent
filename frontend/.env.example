# Dev proxy target is set in frontend/vite.config.js (default http://127.0.0.1:8010).
# Run: uvicorn src.api.main:app --reload --host 127.0.0.1 --port 8010
#
# Optional: call the API directly (bypasses Vite proxy). Requires CORS on the API.
# VITE_API_URL=http://127.0.0.1:8010

# Optional: Unicorn Studio published embed URL (iframe src) for the background.
# VITE_UNICORN_EMBED_URL=
