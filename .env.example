# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Database
DB_NAME=olist
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=localhost
DB_PORT=5432

# App
SECRET_KEY=your_secret_key_here
APP_ENV=development

# Auth (InsightPilot accounts — SQLite file at data/auth.db by default)
# INSIGHTPILOT_AUTH_DB=/absolute/path/to/auth.db
# JWT signing (falls back to SECRET_KEY if unset; set both in production)
# INSIGHTPILOT_JWT_SECRET=long-random-string
# When 0 (recommended), POST /ask requires a Bearer token. When 1, anonymous /ask is allowed (open local API only).
# The Analyze page in the UI always requires sign-in regardless of this flag.
# INSIGHTPILOT_AUTH_OPTIONAL=0
# First admin: set both and restart the API — creates or resets this user to active admin (password min 8 chars).
# INSIGHTPILOT_BOOTSTRAP_ADMIN_EMAIL=you@company.com
# INSIGHTPILOT_BOOTSTRAP_ADMIN_PASSWORD=change-me-now

# Frontend (Vite): dev-only — show “Copy demo snapshot JSON” on Analyze after a successful run
# VITE_DEMO_EXPORT=1

# API: max POST /ask requests per client IP (slowapi). Example: 60/minute
# ASK_RATE_LIMIT=60/minute

# Agent: critic must be at least this confident (0–100) or we ask for clarification first
# ASK_CONFIDENCE_THRESHOLD=70

# After user picks a quick-choice follow-up, still run SQL if critic score is >= this (avoids repeat prompts)
# ASK_FOLLOWUP_OVERRIDE_MIN_SCORE=40

# Optional: salt for stable hashed identifiers in masked API results (set in production)
# INSIGHTPILOT_MASK_SALT=change-me-in-production
